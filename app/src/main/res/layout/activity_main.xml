<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical" android:gravity="center" android:padding="32dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="REVERSI" android:textSize="48sp" android:textStyle="bold" android:layout_marginBottom="32dp"/>
    <Button android:id="@+id/btnNew" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/new_game"/>
    <Button android:id="@+id/btnContinue" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/continue_game"/>
    <Button android:id="@+id/btnSettings" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings"/>
    <Button android:id="@+id/btnExit" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/exit"/>
</LinearLayout>
