<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical" android:gravity="center" android:padding="32dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Select Game Mode" android:textSize="32sp" android:textStyle="bold" android:layout_marginBottom="32dp"/>
    <Button android:id="@+id/btnHumanVsHuman" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Human vs Human"/>
    <Button android:id="@+id/btnHumanVsComputer" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Human vs Computer"/>
</LinearLayout>
